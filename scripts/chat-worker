#!/bin/bash
# Chat with a worker model (qwen2.5-coder:7b on GTX 1060)
# Usage: chat-worker        (in current terminal)
#        chat-worker --new   (opens new terminal window)

# Default to worker on port 11435 (GPU1), can override with --port
PORT=11435
for arg in "$@"; do
    case $arg in
        --port=*) PORT="${arg#*=}" ;;
    esac
done

if [[ "$1" == "--new" || "$2" == "--new" ]]; then
    lxterminal --title="Worker (qwen2.5-coder:7b)" -e "ssh -t gpu 'python3 /home/bryan/llm_orchestration/scripts/chat_runtime.py --port $PORT --model qwen2.5-coder:7b'" &
    disown
else
    ssh -t gpu "python3 /home/bryan/llm_orchestration/scripts/chat_runtime.py --port $PORT --model qwen2.5-coder:7b"
fi
